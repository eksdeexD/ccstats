[Unit]
Description=Claude Code live activity monitor
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/claude-stats/live-monitor.py --verbose
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
