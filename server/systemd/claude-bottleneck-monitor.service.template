[Unit]
Description=Claude Code durable HUMAN BOTTLENECK time accumulator
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/claude-stats/bottleneck-monitor.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
